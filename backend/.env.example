# MongoDB Atlas connection string
# Get this from Atlas -> Connect -> Drivers -> copy the URI, then replace <password>
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/smartqr?retryWrites=true&w=majority

# Port for the backend server
PORT=5000

# Your Next.js frontend URL (for CORS + Socket.io)
CLIENT_ORIGIN=http://localhost:3000

# How long a customer session stays valid after the QR scan (hours)
SESSION_TTL_HOURS=3

# Secret used to sign admin login JWTs. Generate a long random string for
# production, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=8f3a1c9e7b2d4f6a0e8c1b3d5f7a9c2e4b6d8f0a1c3e5b7d9f2a4c6e8b0d3f5a7c9e1b4d6f8a0c2e5b7d9f1a3c6e8b0d